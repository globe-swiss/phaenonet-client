      "@sentry/cli",
      "canvas",
      "esbuild"
    ],
    "overrideComments": {
      "@angular/fire>@angular": "@angular/fire is not released for ng21, keeping version for ng20 until release",
      "@angular/fire>firebase-tools": "@angular/fire peer dep lags behind, safe to ignore (CLI tool only)",
      "@types/google.maps": "pin to version compatible with @angular/google-maps@20 visualization namespace types",
      "canvas": "override from 2.8 -> 3.0 to be able to use binary dependency for resemblejs",
      "diff": "pnpm audit",
      "xml2js": "pnpm audit"
    },
    "overrides": {
      "@types/google.maps": "3.55.x",
      "canvas": "^3.0.0",
      "diff@>=6.0.0 <8.0.3": ">=8.0.3",
      "xml2js@<0.5.0": ">=0.5.0"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@angular/fire>@angular/common": ">=20.0.0",
        "@angular/fire>@angular/core": ">=20.0.0",
        "@angular/fire>@angular/platform-browser": ">=20.0.0",
        "@angular/fire>@angular/platform-browser-dynamic": ">=20.0.0",
        "@angular/fire>firebase-tools": ">=14.0.0"
      }
    }
  },
