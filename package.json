    "ng": "ng",
    "sme": "ng build -c=sme && pnpm dlx source-map-explorer dist/phaenonet/browser/*-es2015.js --html > sme.html",
    "start": "ng serve",
    "start-local": "ng serve --c=local",
    "test": "ng test"
  },
