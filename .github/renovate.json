{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabledManagers": ["github-actions", "npm"],
  "extends": ["config:best-practices"],
  "packageRules": [
    {
      "automerge": true,
      "automergeType": "pr",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["patch"]
    },
    {
      "automerge": true,
      "automergeType": "pr",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor"]
    },
    {
      "automerge": false,
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major"]
    },
    {
      "automerge": false,
      "enabled": true,
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["major"]
    },
    {
      "enabled": false,
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["digest", "minor", "patch", "pin"]
    },
    {
      "automerge": true,
      "automergeType": "pr",
      "enabled": true,
      "matchUpdateTypes": ["lockFileMaintenance"]
    },
    {
      "dependencyDashboardApproval": true,
      "groupName": "angular",
      "matchPackageNames": [
        "/^@angular-devkit//",
        "/^@angular-eslint/",
        "/^@angular//",
        "/^@eslint//",
        "/^@mat-datetimepicker//",
        "/^@types/node/",
        "/^@typescript-eslint//",
        "/^eslint$/",
        "/^rxjs$/",
        "/^tslib$/",
        "/^typescript$/",
        "/^zone.js$/"
      ]
    },
    {
      "groupName": "translate",
      "matchPackageNames": ["/^@ngx-translate//"]
    },
    {
      "description": "Playwright pinned to ~1.51.x due to compatibility issues",
      "enabled": false,
      "matchPackageNames": ["playwright"]
    },
    {
      "description": "Starting with uuid@12 CommonJS is no longer supported.",
      "enabled": false,
      "matchPackageNames": ["uuid"]
    },
    {
      "groupName": "linting",
      "matchPackageNames": [
        "/^@softarc/",
        "/^markdownlint/",
        "/^postcss/",
        "/^stylelint/"
      ]
    },
    {
      "groupName": "d3",
      "matchPackageNames": ["/^@types/d3/", "/^d3/"]
    },
    {
      "groupName": "sentry",
      "matchPackageNames": ["/^@sentry//"]
    },
    {
      "enabled": false,
      "groupName": "prettier",
      "matchPackageNames": ["/^prettier$/"]
    }
  ],
  "schedule": ["after 10pm", "before 6am"]
}
